{
  "version": 2,
  "buildCommand": "python manage.py migrate --noinput && python manage.py collectstatic --noinput",
  "builds": [
    {
      "src": "build/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "build/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "build.settings",
    "PYTHON_VERSION": "3.12"
  }
}
